  "keyFeatures": [
    "Speed limit overrides per lane or segment",
    "Custom lane arrows and turn direction control",
    "Lane connector tool for fine-grained routing",
    "Manual and timed traffic light programming",
    "Priority signs (yield, stop, main road)",
    "Junction restrictions (u-turns, pedestrian crossings, blocked junctions)",
    "Vehicle type restrictions per lane",
    "Parking restrictions",
    "Advanced AI pathfinding options",
    "Save/load traffic configurations with city saves"
  ],
  "publicApiSurface": [
